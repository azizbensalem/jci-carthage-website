SEO_DEFAULT_IMAGE=/images/jci-carthage.png
SEO_ORGANIZATION_TYPE=NGO
SEO_ORGANIZATION_NAME="JCI Carthage"
SEO_LEGAL_NAME="Junior Chamber International Carthage"
SEO_CONTACT_EMAIL=jcicarthage.olm@gmail.com
SEO_CITY=Carthage
SEO_REGION=Tunis
SEO_COUNTRY=TN
SEO_LOGO_PATH=/images/jci-carthage.png
SEO_FACEBOOK_URL=
SEO_INSTAGRAM_URL=
